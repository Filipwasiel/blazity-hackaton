# Copy this file to .env.local and fill in your key.
# The key is read only on the server (app/api/generate/route.ts) and never
# shipped to the browser.

ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default model (claude-sonnet-4-6).
# Use claude-opus-4-8 for higher quality at higher cost.
# CLAUDE_MODEL=claude-sonnet-4-6
