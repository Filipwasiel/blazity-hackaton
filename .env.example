# Copy this file to .env.local and fill in your key.
# The key is read only on the server (app/api/generate/route.ts) and never
# shipped to the browser.

ANTHROPIC_API_KEY=sk-ant-...

# Optional: per-agent model overrides. Generation runs as a team — three
# specialists on cheap models, one lead (Editor-in-Chief) on the strong model.
# Defaults shown; uncomment to change.
# MODEL_COPYWRITER=claude-sonnet-4-6   # LinkedIn, newsletter, article outline
# MODEL_SOCIAL=claude-haiku-4-5        # tweet, video script
# MODEL_ART=claude-haiku-4-5           # image prompt
# MODEL_LEAD=claude-opus-4-8           # review, unify voice, final JSON
